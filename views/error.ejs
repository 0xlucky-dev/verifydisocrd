<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>เกิดข้อผิดพลาด</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="floating-bg" id="floatingBg"></div>

  <div class="container">
    <div class="card">
      <div class="icon-wrap error">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--error)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
      </div>
      <h1>เกิดข้อผิดพลาด</h1>
      <p class="sub"><%= message %></p>
      <a href="javascript:history.back()" class="btn secondary">ลองใหม่</a>
    </div>
  </div>

  <script>
    (function() {
      const bg = document.getElementById('floatingBg');
      const sizes = [30, 40, 50, 60, 70, 80];
      for (let i = 0; i < 12; i++) {
        const img = document.createElement('img');
        img.src = '/logo.png';
        img.className = 'floating-logo';
        const size = sizes[Math.floor(Math.random() * sizes.length)];
        img.style.width = size + 'px';
        img.style.left = Math.random() * 100 + '%';
        img.style.top = Math.random() * 100 + '%';
        img.style.animationDuration = (15 + Math.random() * 20) + 's';
        img.style.animationDelay = (-Math.random() * 20) + 's';
        bg.appendChild(img);
      }
    })();
  </script>
</body>
</html>
